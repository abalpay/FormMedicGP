stream
/* * Depending on value of No/Yes checkbox lock or unlock array of fields */function lockUnlockNoYes(NoYesField, UnlockValue, FieldsToLockUnlock) {    var NoYes = NoYesField.value;    var ArrayToLockUnlock = FieldsToLockUnlock.split(",");    if (NoYes == UnlockValue) {        ReadonlyVal = false;    } else {        ReadonlyVal = true;    }      for (i = 0; i< ArrayToLockUnlock.length; i++) {        var FieldInArray = this.getField(ArrayToLockUnlock[i]);        if (ReadonlyVal) {	        FieldInArray.display = display.hidden;                    if (FieldInArray.type == "text") {                FieldInArray.value = "";            } else if (FieldInArray.type == "checkbox") {                FieldInArray.value = "Off";            }        } else {	        FieldInArray.display = display.visible;	    }    }}
endstream
endobj

