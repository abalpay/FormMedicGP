{
  "formId": "SU415",
  "formName": "Centrelink Medical Certificate (SU415)",
  "templatePath": "templates/SU415.pdf",
  "sections": {
    "patient": {
      "source": "manual_entry",
      "fields": {
        "familyName": {
          "label": "Family Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.FamilyName",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "firstName": {
          "label": "First Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.FirstName",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "secondName": {
          "label": "Second Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.SecondName",
          "pdfFieldType": "text"
        },
        "dateOfBirth": {
          "label": "Date Of Birth",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "Patient.DOB1.D",
            "Patient.DOB1.M",
            "Patient.DOB1.Y"
          ],
          "pdfFieldType": "split-date",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "crn": {
          "label": "Crn",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": [
            "Q1CRN.0",
            "Q1CRN.1",
            "Q1CRN.2",
            "Q1CRN.3"
          ],
          "pdfFieldType": "split-chars",
          "optional": true
        },
        "address1": {
          "label": "Address1",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.Address1",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "address2": {
          "label": "Address2",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.Address2",
          "pdfFieldType": "text"
        },
        "address3": {
          "label": "Address3",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.Address3",
          "pdfFieldType": "text"
        },
        "postcode": {
          "label": "Postcode",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Patient.Postcode",
          "pdfFieldType": "text"
        }
      }
    },
    "doctor": {
      "source": "doctor_profile",
      "fields": {
        "doctorName": {
          "label": "Doctor Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Name",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "qualifications": {
          "label": "Qualifications",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Quals",
          "pdfFieldType": "text"
        },
        "providerNumber": {
          "label": "Provider Number",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.ProvNo",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "surgeryName": {
          "label": "Surgery Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.SurgeryName",
          "pdfFieldType": "text"
        },
        "doctorAddress1": {
          "label": "Doctor Address1",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Address1",
          "pdfFieldType": "text"
        },
        "doctorAddress2": {
          "label": "Doctor Address2",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Address2",
          "pdfFieldType": "text"
        },
        "doctorAddress3": {
          "label": "Doctor Address3",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Address3",
          "pdfFieldType": "text"
        },
        "doctorPostcode": {
          "label": "Doctor Postcode",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.Postcode",
          "pdfFieldType": "text"
        },
        "phone": {
          "label": "Phone",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Dr.PhoneNo",
          "pdfFieldType": "text"
        },
        "dateSigned": {
          "label": "Date Signed",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "DateSigned1.D",
            "DateSigned1.M",
            "DateSigned1.Y"
          ],
          "pdfFieldType": "split-date",
          "default": "today"
        },
        "signature": {
          "label": "Signature",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Sign",
          "pdfFieldType": "text"
        }
      }
    },
    "clinical": {
      "source": "llm_extraction",
      "fields": {
        "primaryDiagnosis": {
          "label": "Primary Diagnosis",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "PC.Diagnosis",
          "pdfFieldType": "text",
          "required": true,
          "llmInstruction": "Extract the primary diagnosis using proper medical terminology. Keep brief — 1-2 short sentences max.",
          "validation": {
            "required": true
          }
        },
        "primaryOnsetDate": {
          "label": "Primary Onset Date",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "PC.OnsetDate1.D",
            "PC.OnsetDate1.M",
            "PC.OnsetDate1.Y"
          ],
          "pdfFieldType": "split-date",
          "required": true,
          "llmInstruction": "Date the primary condition began or was first diagnosed. Use YYYY-MM-DD format.",
          "validation": {
            "required": true
          }
        },
        "primaryPrognosis": {
          "label": "Expected Duration of Impact",
          "inputType": "select",
          "reviewControl": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "PC.Prognosis",
          "pdfFieldType": "checkbox",
          "options": [
            "up_to_13_weeks",
            "13_to_24_months",
            "more_than_24_months"
          ],
          "pdfOptions": {
            "up_to_13_weeks": "#233c3",
            "13_to_24_months": "13-24",
            "more_than_24_months": "24+"
          },
          "optionLabels": {
            "up_to_13_weeks": "Up to 13 weeks",
            "13_to_24_months": "13 weeks to 24 months",
            "more_than_24_months": "More than 24 months"
          },
          "required": true,
          "llmInstruction": "Expected duration of functional impact for the primary condition: 'up_to_13_weeks' for temporary/short-term, '13_to_24_months' for medium-term, 'more_than_24_months' for chronic/permanent. Most acute conditions are 'up_to_13_weeks'.",
          "validation": {
            "required": true,
            "enum": [
              "up_to_13_weeks",
              "13_to_24_months",
              "more_than_24_months"
            ]
          }
        },
        "terminalIllness": {
          "label": "Terminal Illness",
          "inputType": "select",
          "reviewControl": "segmented",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "PC.LE24OrLess",
          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "pdfOptions": {
            "yes": "Yes",
            "no": "No"
          },
          "required": true,
          "default": "no",
          "llmInstruction": "Is the patient's life expectancy 24 months or less? Default 'no' unless explicitly stated.",
          "validation": {
            "required": true,
            "enum": [
              "yes",
              "no"
            ]
          }
        },
        "seriousIllness": {
          "label": "Serious Illness",
          "inputType": "select",
          "reviewControl": "segmented",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "PC.MeetSeriousIllness",
          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "pdfOptions": {
            "yes": "Yes",
            "no": "No"
          },
          "required": true,
          "default": "no",
          "tooltip": "Serious illness includes conditions such as cancer, organ failure, major trauma, or severe mental health conditions requiring intensive treatment.",
          "llmInstruction": "Does the condition meet Centrelink's serious illness criteria? Default 'no' unless the condition is clearly severe (e.g., cancer, organ failure, major trauma).",
          "validation": {
            "required": true,
            "enum": [
              "yes",
              "no"
            ]
          }
        },
        "secondaryDiagnosis": {
          "label": "Secondary Diagnosis",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "SC.Diagnosis",
          "pdfFieldType": "text",
          "emptyHint": "No secondary condition detected from your description.",
          "llmInstruction": "Extract any secondary/additional diagnosis if mentioned. Omit if only one condition discussed."
        },
        "secondaryOnsetDate": {
          "label": "Secondary Onset Date",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "SC.OnsetDate1.D",
            "SC.OnsetDate1.M",
            "SC.OnsetDate1.Y"
          ],
          "pdfFieldType": "split-date",
          "hiddenWhenEmpty": "secondaryDiagnosis",
          "llmInstruction": "Date the secondary condition began. Only extract if a secondary diagnosis exists."
        },
        "secondaryPrognosis": {
          "label": "Expected Duration of Impact",
          "inputType": "select",
          "reviewControl": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "SC.Prognosis",
          "pdfFieldType": "checkbox",
          "options": [
            "up_to_13_weeks",
            "13_to_24_months",
            "more_than_24_months"
          ],
          "pdfOptions": {
            "up_to_13_weeks": "#233c3",
            "13_to_24_months": "13-24",
            "more_than_24_months": "24+"
          },
          "optionLabels": {
            "up_to_13_weeks": "Up to 13 weeks",
            "13_to_24_months": "13 weeks to 24 months",
            "more_than_24_months": "More than 24 months"
          },
          "hiddenWhenEmpty": "secondaryDiagnosis",
          "llmInstruction": "Expected duration of functional impact for the secondary condition. Only extract if a secondary diagnosis exists.",
          "validation": {
            "enum": [
              "up_to_13_weeks",
              "13_to_24_months",
              "more_than_24_months"
            ]
          }
        },
        "functionalImpact": {
          "label": "Functional Impact",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "FunctionalImpact",
          "pdfFieldType": "text",
          "required": true,
          "highlight": true,
          "llmInstruction": "Describe the functional impact of the conditions on the patient's ability to work, study, or participate. Be specific about limitations (e.g., 'unable to sit for >20 minutes', 'cannot lift >5kg'). This is critical for Centrelink acceptance.",
          "validation": {
            "required": true
          }
        },
        "treatment": {
          "label": "Treatment",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Treatment",
          "pdfFieldType": "text",
          "required": true,
          "highlight": true,
          "llmInstruction": "Describe past, current, and planned treatment. Include medications, therapies, and follow-up plans. Keep to 2-3 short sentences — the text area is compact.",
          "validation": {
            "required": true
          }
        },
        "otherConditions": {
          "label": "Other Conditions",
          "inputType": "select",
          "reviewControl": "segmented",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "OC.OtherConditions",
          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "pdfOptions": {
            "yes": "Yes",
            "no": "No"
          },
          "default": "no",
          "llmInstruction": "Are there other conditions affecting the patient? Default 'no' unless multiple conditions are discussed beyond primary and secondary.",
          "validation": {
            "enum": [
              "yes",
              "no"
            ]
          }
        },
        "incapacityStartDate": {
          "label": "Incapacity Start Date",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "Incapacity.From1.D",
            "Incapacity.From1.M",
            "Incapacity.From1.Y"
          ],
          "pdfFieldType": "split-date",
          "required": true,
          "llmInstruction": "When the patient became unfit for work/study. If not stated, use today's date.",
          "validation": {
            "required": true
          }
        },
        "incapacityEndDate": {
          "label": "Incapacity End Date",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "Incapacity.To1.D",
            "Incapacity.To1.M",
            "Incapacity.To1.Y"
          ],
          "pdfFieldType": "split-date",
          "required": true,
          "llmInstruction": "Expected date the patient can return to work/study. Calculate from duration mentioned. Max 13 weeks (91 days) for standard exemption.",
          "validation": {
            "required": true
          }
        },
        "workCapacity": {
          "label": "Work Capacity",
          "inputType": "select",
          "reviewControl": "segmented",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Capacity.8HoursPlus",
          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "pdfOptions": {
            "yes": "Yes",
            "no": "No"
          },
          "required": true,
          "llmInstruction": "Can the patient work, study, or do training for 8 or more hours per week? 'yes' if partially capable, 'no' if completely incapacitated.",
          "validation": {
            "required": true,
            "enum": [
              "yes",
              "no"
            ]
          }
        },
        "hoursPerWeek": {
          "label": "Hours Per Week",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "HoursWork",
          "pdfFieldType": "text",
          "conditional": "workCapacity === 'yes'",
          "llmInstruction": "If the patient can do some work, how many hours per week? Output a NUMBER ONLY (e.g. '15'), not a sentence. Only extract if workCapacity is 'yes'."
        }
      }
    }
  },
  "systemPromptAdditions": "For Centrelink SU415 medical certificates:\n- The 'functionalImpact' field is CRITICAL — describe HOW conditions affect daily functioning and work capacity with specific limitations (e.g., 'cannot stand >15min', 'unable to concentrate for sustained periods').\n- The 'treatment' field should cover past, current, and planned treatment to show the condition is being properly managed.\n- For prognosis fields, choose the most appropriate duration category.\n- Default 'terminalIllness' and 'seriousIllness' to 'no' unless clearly indicated.\n- 'incapacityStartDate' is when the patient became unfit; use today if not specified.\n- 'incapacityEndDate' should not exceed 13 weeks (91 days) from start for standard exemptions.",
  "formVersion": "2024-12",
  "dictationGuide": [
    {
      "id": "diagnosisTreatment",
      "title": "Diagnosis & Treatment",
      "description": "Describe the condition, functional impact, and treatment plan",
      "questions": [
        {
          "key": "diagnosisNarrative",
          "label": "Clinical Narrative",
          "inputType": "textarea",
          "description": "What is the condition, how does it affect function, and what's the treatment?",
          "placeholder": "e.g. Lumbar disc herniation L4/5 causing radiculopathy. Unable to sit >20min or lift >5kg. On pregabalin 75mg BD, referred for physio and epidural injection.",
          "requiredForBestFill": true
        }
      ]
    },
    {
      "id": "workCapacitySection",
      "title": "Work Capacity",
      "description": "Can the patient work 8+ hours per week?",
      "questions": [
        {
          "key": "workCapacity",
          "label": "Work Capacity (8+ hrs/week)",
          "inputType": "segmented",
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ],
          "targetFieldKey": "workCapacity",
          "requiredForBestFill": true
        },
        {
          "key": "hoursPerWeek",
          "label": "Hours Per Week",
          "inputType": "number",
          "placeholder": "e.g. 15",
          "targetFieldKey": "hoursPerWeek",
          "visibleWhen": { "key": "workCapacity", "equals": "yes" }
        }
      ]
    },
    {
      "id": "durationIncapacity",
      "title": "Duration & Incapacity Period",
      "description": "Expected duration of functional impact and incapacity dates",
      "questions": [
        {
          "key": "primaryPrognosis",
          "label": "Expected Duration of Impact",
          "inputType": "segmented",
          "options": [
            { "value": "up_to_13_weeks", "label": "Up to 13 weeks" },
            { "value": "13_to_24_months", "label": "13 weeks – 24 months" },
            { "value": "more_than_24_months", "label": "24+ months" }
          ],
          "targetFieldKey": "primaryPrognosis",
          "requiredForBestFill": true
        },
        {
          "key": "incapacityStartDate",
          "label": "Incapacity Start Date",
          "inputType": "date",
          "targetFieldKey": "incapacityStartDate",
          "requiredForBestFill": true
        },
        {
          "key": "incapacityEndDate",
          "label": "Incapacity End Date",
          "inputType": "date",
          "targetFieldKey": "incapacityEndDate",
          "requiredForBestFill": true
        }
      ]
    },
    {
      "id": "terminalSerious",
      "title": "Terminal & Serious Illness",
      "description": "Usually both No — only select Yes if clearly indicated",
      "questions": [
        {
          "key": "terminalIllness",
          "label": "Terminal Illness (life expectancy ≤24 months)",
          "inputType": "segmented",
          "options": [
            { "value": "no", "label": "No" },
            { "value": "yes", "label": "Yes" }
          ],
          "targetFieldKey": "terminalIllness",
          "defaultValue": "no"
        },
        {
          "key": "seriousIllness",
          "label": "Serious Illness",
          "inputType": "segmented",
          "options": [
            { "value": "no", "label": "No" },
            { "value": "yes", "label": "Yes" }
          ],
          "targetFieldKey": "seriousIllness",
          "defaultValue": "no"
        }
      ]
    }
  ],
  "dictationTips": [
    "What is the primary diagnosis?",
    "When did the condition start, and how long is recovery expected to take?",
    "How does this condition affect their ability to work or study day-to-day?",
    "What treatment have they had, and what is the current management plan?",
    "When did they become unfit, and when can they return to work?",
    "Can they do any work at all — if so, how many hours per week?"
  ],
  "allowedUnmappedPdfFields": [
    "Clear",
    "Instructions"
  ]
}
