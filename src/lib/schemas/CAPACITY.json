          "label": "Worker First Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker First Name",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "familyName": {
          "label": "Worker Last Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
