{
  "formId": "CAPACITY",
  "formName": "Certificate of Capacity (Victoria TAC/WorkCover)",
  "formVersion": "2024-11",
  "templatePath": "templates/CAPACITY.pdf",
  "dictationTips": [
    "What is the clinical diagnosis and anatomical site?",
    "What are the specific physical or mental restrictions — lifting, standing, concentration, driving?",
    "From when to when is the patient unfit for work?",
    "What is the treatment plan and expected return-to-work timeline?",
    "Are there any work environment considerations or duties they can still perform?"
