          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Postcode",
          "pdfFieldType": "text",
          "validation": {
            "pattern": "^\\d{4}$"
          }
        },
        "dateOfBirth": {
          "label": "Date Of Birth",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "Date of Birth Day",
            "Date of Birth Month",
            "Date of Birth Year"
