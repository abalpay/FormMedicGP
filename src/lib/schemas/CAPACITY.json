{
  "formId": "CAPACITY",
  "formName": "Certificate of Capacity (Victoria TAC/WorkCover)",
  "formVersion": "2024-11",
  "templatePath": "templates/CAPACITY.pdf",
  "dictationTips": [
    "What is the clinical diagnosis and anatomical site?",
    "What are the specific physical or mental restrictions — lifting, standing, concentration, driving?",
    "From when to when is the patient unfit for work?",
    "What is the treatment plan and expected return-to-work timeline?",
    "Are there any work environment considerations or duties they can still perform?"
  ],
  "sections": {
    "patient": {
      "source": "manual_entry",
      "fields": {
        "firstName": {
          "label": "Worker First Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker First Name",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "familyName": {
          "label": "Worker Last Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker Last Name",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "secondName": {
          "label": "Additional Last Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker Last Name cont",
          "pdfFieldType": "text"
        },
        "address1": {
          "label": "Worker Address",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker Address",
          "pdfFieldType": "text"
        },
        "address2": {
          "label": "Worker Address Continued",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker Address cont",
          "pdfFieldType": "text"
        },
        "postcode": {
          "label": "Postcode",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Postcode",
          "pdfFieldType": "text",
          "validation": {
            "pattern": "^\\d{4}$"
          }
        },
        "dateOfBirth": {
          "label": "Date Of Birth",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": [
            "Date of Birth Day",
            "Date of Birth Month",
            "Date of Birth Year"
          ],
          "pdfFieldType": "split-date",
          "required": true,
          "validation": {
            "required": true,
            "dateMax": "today"
          }
        },
        "claimNumber": {
          "label": "Claim Number",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Claim Number if known",
          "pdfFieldType": "text"
        }
      }
