          "options": [
            "pre_injury_capacity",
            "suitable_employment",
            "no_capacity"
          ],
          "optionLabels": {
            "pre_injury_capacity": "Pre-injury Employment",
            "suitable_employment": "Suitable Employment",
            "no_capacity": "No Capacity"
