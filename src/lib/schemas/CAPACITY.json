          "label": "TAC Claim",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "reviewGroup": "claimAndCertificate",
          "pdfField": "TAC Claim",
          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "optionLabels": {
            "yes": "Yes",
            "no": "No"
          },
          "reviewControl": "segmented",
          "llmInstruction": "Set yes when the injury/condition is described as a TAC motor vehicle claim; otherwise set no unless both claim types are explicitly stated."
        },
        "vwaClaim": {
          "label": "VWA Claim",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "reviewGroup": "claimAndCertificate",
