          "reviewControl": "segmented",
          "validation": {
            "enum": [
              "pre_injury_capacity",
              "suitable_employment",
              "no_capacity"
            ]
          },
          "llmInstruction": "Choose one value: pre_injury_capacity, suitable_employment, or no_capacity based on the stated work capacity outcome."
