          "pdfFieldType": "checkbox",
          "options": [
            "yes",
            "no"
          ],
          "optionLabels": {
            "yes": "Yes",
            "no": "No"
          },
          "reviewControl": "segmented",
          "llmInstruction": "Set yes when the injury/condition is described as a WorkSafe/VWA claim; otherwise set no unless both claim types are explicitly stated."
