          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "secondName": {
          "label": "Additional Last Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Worker Last Name cont",
          "pdfFieldType": "text"
