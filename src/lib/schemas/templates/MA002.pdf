// This script resets a form// if ok(1)/yes(4) then reset form// if cancel(2)/no(3), nothing happens// -------------------------alertReset = app.alert("Are you sure you want to clear this form?",2,2);if(alertReset == 1 | alertReset == 4){    this.resetForm();    } 
endstream
endobj

