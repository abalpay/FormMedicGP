{
  "formId": "MA002",
  "formName": "Mobility Allowance Medical Report (MA002)",
  "formVersion": "2006-06",
  "templatePath": "templates/MA002.pdf",
  "dictationTips": [
    "What condition affects the patient's mobility?",
    "How does it limit their ability to use public transport?",
    "What are their specific physical limitations — walking distance, standing tolerance, transfers?",
    "What treatment or rehabilitation have they had, and what is the outlook?",
    "Is this limitation temporary or long-term?"
  ],
  "sections": {
    "patient": {
      "source": "manual_entry",
      "fields": {
        "fullName": {
          "label": "Customer Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "CustName",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "address1": {
          "label": "Address1",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "CustAddress1",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "address2": {
          "label": "Address2",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "CustAddress2",
          "pdfFieldType": "text"
        },
        "postcode": {
          "label": "Postcode",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "CustPostcode",
          "pdfFieldType": "text",
          "validation": {
            "pattern": "^\\d{4}$"
          }
        },
        "dateOfBirth": {
          "label": "Date Of Birth",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": "CustDateOfBirth",
          "pdfFieldType": "date-text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "crn": {
          "label": "CRN",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": [
            "CustCRN.0",
            "CustCRN.1",
            "CustCRN.2",
            "CustCRN.3"
          ],
          "pdfFieldType": "split-chars"
        }
      }
    },
    "doctor": {
      "source": "doctor_profile",
      "fields": {
        "doctorName": {
          "label": "Doctor Name",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorName",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "qualifications": {
          "label": "Qualifications",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorQual",
          "pdfFieldType": "text"
        },
        "providerNumber": {
          "label": "Provider Number",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "ProviderNo",
          "pdfFieldType": "text",
          "required": true,
          "validation": {
            "required": true
          }
        },
        "doctorAddress1": {
          "label": "Doctor Address1",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorAddress1",
          "pdfFieldType": "text"
        },
        "doctorAddress2": {
          "label": "Doctor Address2",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorAddress2",
          "pdfFieldType": "text"
        },
        "doctorAddress3": {
          "label": "Doctor Address3",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorAddress3",
          "pdfFieldType": "text"
        },
        "doctorPostcode": {
          "label": "Doctor Postcode",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorPostcode",
          "pdfFieldType": "text",
          "validation": {
            "pattern": "^\\d{4}$"
          }
        },
        "doctorPhoneAreaCode": {
          "label": "Doctor Phone Area Code",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorPhoneAC",
          "pdfFieldType": "text"
        },
        "doctorPhoneNumber": {
          "label": "Doctor Phone Number",
          "inputType": "text",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "DoctorPhoneNo",
          "pdfFieldType": "text"
        },
        "dateSigned": {
          "label": "Date Signed",
          "inputType": "date",
          "reviewEditable": true,
          "type": "date",
          "pdfField": "DoctorSignDate",
          "pdfFieldType": "date-text",
          "required": true,
          "default": "today",
          "validation": {
            "required": true
          }
        }
      }
    },
    "clinical": {
      "source": "llm_extraction",
      "fields": {
        "mobilityClinicalSummary": {
          "label": "Clinical Mobility Summary",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Q10Details",
          "pdfFieldType": "text",
          "required": true,
          "llmInstruction": "Summarize clinical diagnosis and mobility impact relevant to allowance eligibility.",
          "validation": {
            "required": true
          }
        },
        "mobilityFunctionalImpact": {
          "label": "Functional Impact",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Q7Details",
          "pdfFieldType": "text",
          "llmInstruction": "Describe practical mobility restrictions and transport barriers."
        },
        "hasPhysicalDisabilities": {
          "label": "Has Physical Disabilities",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Q3",
          "pdfFieldType": "checkbox",
          "options": ["yes", "no"],
          "optionLabels": { "yes": "Yes", "no": "No" },
          "default": "yes",
          "reviewControl": "segmented",
          "llmInstruction": "Set 'yes' if physical disabilities affecting mobility are described. Default 'yes' since this form is about mobility."
        },
        "physicalDisabilitiesDetails": {
          "label": "Physical Disabilities Details",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Q3Details",
          "pdfFieldType": "text",
          "llmInstruction": "Describe physical disabilities and how they affect mobility and ability to use public transport."
        },
        "hasPsychiatricDisabilities": {
          "label": "Has Psychiatric/Intellectual Disabilities",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Q5",
          "pdfFieldType": "checkbox",
          "options": ["yes", "no"],
          "optionLabels": { "yes": "Yes", "no": "No" },
          "default": "no",
          "reviewControl": "segmented",
          "llmInstruction": "Set 'yes' if psychiatric or intellectual disabilities are described. Default 'no'."
        },
        "psychiatricDisabilitiesDetails": {
          "label": "Psychiatric/Intellectual Details",
          "inputType": "textarea",
          "reviewEditable": true,
          "type": "text",
          "pdfField": "Q5Details",
          "pdfFieldType": "text",
          "llmInstruction": "Describe psychiatric or intellectual disabilities and how they affect ability to use public transport."
        },
        "hasOtherTransportInfo": {
          "label": "Has Other Transport Info",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Q7",
          "pdfFieldType": "checkbox",
          "options": ["yes", "no"],
          "optionLabels": { "yes": "Yes", "no": "No" },
          "default": "no",
          "reviewControl": "segmented",
          "llmInstruction": "Set 'yes' if there is additional transport limitation information beyond physical and psychiatric. Default 'no'."
        },
        "mobilityPermanentOrTemporary": {
          "label": "Permanent or Temporary",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Q8",
          "pdfFieldType": "checkbox",
          "options": ["permanent", "temporary"],
          "optionLabels": { "permanent": "Permanent", "temporary": "Temporary" },
          "reviewControl": "segmented",
          "llmInstruction": "Is the mobility limitation permanent or temporary?"
        },
        "mobilityDuration": {
          "label": "Duration",
          "inputType": "select",
          "reviewEditable": true,
          "type": "checkbox",
          "pdfField": "Q9",
          "pdfFieldType": "checkbox",
          "options": ["less_than_12_months", "12_months_or_longer"],
          "optionLabels": { "less_than_12_months": "Less than 12 months", "12_months_or_longer": "12 months or longer" },
          "reviewControl": "segmented",
          "llmInstruction": "If temporary, will the mobility limitation last less than 12 months or 12 months or longer?"
        }
      }
    }
  },
  "systemPromptAdditions": "For MA002 emphasize mobility limitations, transport barriers, persistence of impairment, and current treatment response.\n- Extract physical disability details into 'physicalDisabilitiesDetails' (maps to Q3Details on PDF).\n- If psychiatric/intellectual disabilities are mentioned, set 'hasPsychiatricDisabilities' to 'yes' and extract details into 'psychiatricDisabilitiesDetails'.\n- Extract overall functional impact into 'mobilityFunctionalImpact' and clinical summary into 'mobilityClinicalSummary'.\n- Set 'hasOtherTransportInfo' to 'yes' and populate 'mobilityFunctionalImpact' if transport-specific info exists beyond physical/psychiatric categories.",
  "allowedUnmappedPdfFields": [
    "Clear",
    "CliamNo",
    "CustPhoneAC",
    "CustPhoneNo",
    "DummyCalcQ10",
    "DummyCalcQ2",
    "DummyCalcQ3",
    "DummyCalcQ5",
    "DummyCalcQ7",
    "DummyCalcQ8",
    "Instructions",
    "Print",
    "Q10",
    "Q2",
    "Q2GoToQ11",
    "Q2PatientSince",
    "Q2PracticeSince",
    "Q3GoToQ5",
    "Q41",
    "Q42",
    "Q43",
    "Q44",
    "Q45",
    "Q46",
    "Q5GoToQ7",
    "Q61",
    "Q62",
    "Q63",
    "Q64",
    "Q8GoToQ10",
    "Sign"
  ],
  "dictationGuide": [
    {
      "id": "conditionAndPrognosis",
      "title": "Condition & Prognosis",
      "description": "Indicate the nature and duration of the mobility limitation.",
      "questions": [
        {
          "key": "hasPhysicalDisabilities",
          "label": "Physical Disabilities?",
          "inputType": "segmented",
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ],
          "targetFieldKey": "hasPhysicalDisabilities",
          "defaultValue": "yes",
          "requiredForBestFill": true
        },
        {
          "key": "hasPsychiatricDisabilities",
          "label": "Psychiatric/Intellectual Disabilities?",
          "inputType": "segmented",
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ],
          "targetFieldKey": "hasPsychiatricDisabilities",
          "defaultValue": "no"
        },
        {
          "key": "permanentOrTemporary",
          "label": "Permanent or Temporary",
          "inputType": "segmented",
          "options": [
            { "value": "permanent", "label": "Permanent" },
            { "value": "temporary", "label": "Temporary" }
          ],
          "targetFieldKey": "mobilityPermanentOrTemporary",
          "requiredForBestFill": true
        },
        {
          "key": "mobilityDuration",
          "label": "Duration if Temporary",
          "inputType": "segmented",
          "options": [
            { "value": "less_than_12_months", "label": "Less than 12 months" },
            { "value": "12_months_or_longer", "label": "12 months or longer" }
          ],
          "targetFieldKey": "mobilityDuration",
          "visibleWhen": { "key": "permanentOrTemporary", "equals": "temporary" }
        }
      ]
    },
    {
      "id": "clinicalNarrative",
      "title": "Clinical Narrative",
      "description": "Describe the patient's mobility condition, how it affects their ability to use public transport, and current treatment.",
      "questions": [
        {
          "key": "clinicalNarrative",
          "label": "Mobility & Transport Impact",
          "inputType": "textarea",
          "placeholder": "e.g. Severe bilateral knee OA with valgus deformity. Cannot walk >100m, unable to negotiate steps, serious difficulty standing on moving transport. Uses walking frame. Awaiting TKR. Also has anxiety limiting ability to navigate unfamiliar environments.",
          "requiredForBestFill": true
        }
      ]
    }
  ]
}
